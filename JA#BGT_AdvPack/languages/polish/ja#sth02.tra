@0 = ~Hm? Cz... czasy *czka* nie są łaskawe dla takich szumowin jak my. *czka* Coś wam powiem!~
@1 = ~Przetrwońcie łup z dziwkami! Albo złóżcie ofiarę Władcy Cieni, jeśli... *czka*... uważacie, że tak będzie lepiej.~
@2 = ~Władcy Cieni?~
@3 = ~Masz na myśli Maskę?~
@4 = ~Ma-... Maskę! Wiecie o nim? Idźcie obok, do Ciszy, jeśli... *czka*... chcecie mu coś tam ofiarować.~
// @5 = ~Dzięki, tak zrobię.~
@6 = ~*czka* Co? Słucham?~
@7 = ~Hm?~
@8 = ~Uch *czka*... Przeklęta gorzała!~
@9 = ~Uch *czka*... Czyli już wiecie o tej kapliczce u Ciszy, co? No, no. Trochę boskiej pomocy nikomu jeszcze nie zaszkodziło.~