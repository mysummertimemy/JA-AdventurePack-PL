@34 = ~Hej, ty! Wynoś się stąd! Nie masz prawa przebywać w piwnicach pałacu.~
@35 = ~Dobrze, już wychodzę.~
@36 = ~I tu się mylisz! Przepuść nas, albo będę musiał dobyć broni!~ ~I tu się mylisz! Przepuść nas, albo będę musiała dobyć broni!~
@37 = ~Tu chodzi o sprawę życia i śmierci! Mam do wykonania ważne zadanie.~
@38 = ~Ha! Zobaczymy, na co cię stać. Angelo Dosan ostrzegał nas przed tobą!~
@39 = ~Ha! Przejrzałem twoje zamiary! Angelo Dosan ostrzegał nas przed tobą!~